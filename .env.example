# Credenciais MTProto — obter em https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# String de sessão gerada pelo auth.js (rode npm run auth uma vez localmente)
TELEGRAM_SESSION=

# Nome exato do grupo a monitorar
TELEGRAM_GROUP_NAME=OPERAÇÃO QSEMST - ES - BNL

# Chave da API Anthropic (Claude extrai estrutura do texto OCR — sem imagem, muito barato)
ANTHROPIC_API_KEY=

# Chave da API Google Vision (OCR das imagens do Diário de Bordo)
GOOGLE_VISION_API_KEY=

# PostgreSQL Railway (desvios-bot — tabelas processed_messages e desvios)
DATABASE_URL=postgresql://postgres:SENHA@postgres.railway.internal:5432/railway

# PostgreSQL Neon (banco principal — cadastro_pessoas para buscar matrícula e corrigir nomes)
NEON_DATABASE_URL=postgresql://neondb_owner:SENHA@ep-xxx.neon.tech/neondb?sslmode=require

# ID Telegram do remetente dos relatórios (obter com auth.js ou /getid)
# Deixe em branco para aceitar imagens de qualquer remetente no grupo
TELEGRAM_SENDER_ID=

# Token do desviosbot (BotFather)
DESVIOS_BOT_TOKEN=

# Seu Chat ID no Telegram (onde o bot vai te enviar os resumos)
TELEGRAM_MY_CHAT_ID=
